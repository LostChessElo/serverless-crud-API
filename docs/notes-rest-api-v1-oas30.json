{
  "openapi": "3.0.1",
  "info": {
    "title": "notes-rest-api",
    "description": "A serverless REST API for managing notes (CRUD) on AWS Lambda + API Gateway + DynamoDB.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://cv1czgs8wh.execute-api.af-south-1.amazonaws.com/{basePath}",
      "variables": {
        "basePath": {
          "default": "v1"
        }
      }
    }
  ],
  "paths": {
    "/notes": {
      "get": {
        "summary": "List all notes",
        "description": "Returns every note. Returns an empty array if there are none.",
        "responses": {
          "200": {
            "description": "A list of notes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Note"
                  }
                },
                "examples": {
                  "withData": {
                    "value": [
                      {
                        "id": "b1a99c1e-8d6e-4d4d-8bfe-d06ce4193615",
                        "name": "groceries",
                        "description": "milk, eggs"
                      }
                    ]
                  },
                  "empty": {
                    "value": []
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      },
      "post": {
        "summary": "Create a note",
        "description": "Creates a note. `name` is required and cannot be null. `description` must be present in the body but its value may be null.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteCreate"
              },
              "example": {
                "name": "groceries",
                "description": "milk, eggs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Note created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                },
                "example": {
                  "message": "Note added successfully."
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/notes/{id}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/NoteId"
        }
      ],
      "patch": {
        "summary": "Update a note",
        "description": "Updates a note's fields. Any field may be omitted; an omitted field is left unchanged. An empty body returns the existing note unchanged.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteUpdate"
              },
              "examples": {
                "updateBoth": {
                  "value": {
                    "name": "updated name",
                    "description": "updated description"
                  }
                },
                "nameOnly": {
                  "value": {
                    "name": "only the name changed"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated (or unchanged) note",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Note"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      },
      "delete": {
        "summary": "Delete a note",
        "responses": {
          "200": {
            "description": "Note deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                },
                "example": {
                  "message": "Note deleted successfully."
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "NoteId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "The note's unique identifier.",
        "schema": {
          "type": "string"
        },
        "example": "b1a99c1e-8d6e-4d4d-8bfe-d06ce4193615"
      }
    },
    "schemas": {
      "Note": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "b1a99c1e-8d6e-4d4d-8bfe-d06ce4193615"
          },
          "name": {
            "type": "string",
            "example": "groceries"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "milk, eggs"
          }
        }
      },
      "NoteCreate": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "groceries"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "milk, eggs"
          }
        }
      },
      "NoteUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "updated name"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "updated description"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request (missing/invalid fields or malformed body)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Message"
            },
            "example": {
              "message": "Bad request."
            }
          }
        }
      },
      "NotFound": {
        "description": "Note not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Message"
            },
            "example": {
              "message": "Note not found."
            }
          }
        }
      },
      "ServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Message"
            }
          }
        }
      }
    }
  }
}